# OS-APOW Environment Variables Template
# Copy this file to .env and fill in your values

# ===========================================
# Required Configuration
# ===========================================

# GitHub App installation token or Personal Access Token
# Required permissions: repo, issues, pull_requests
GITHUB_TOKEN=your-github-token-here

# GitHub organization name (owner of the repository)
GITHUB_ORG=your-org-name

# Target repository name
GITHUB_REPO=your-repo-name

# ===========================================
# Optional Configuration
# ===========================================

# Bot account login for assign-then-verify locking
# Used to prevent race conditions between multiple Sentinel instances
# SENTINEL_BOT_LOGIN=

# GitHub App webhook secret for HMAC verification (Phase 2)
# Generate a secure random string: openssl rand -hex 32
# WEBHOOK_SECRET=

# ===========================================
# Infrastructure Configuration
# ===========================================

# Redis connection URL
REDIS_URL=redis://localhost:6379/0

# ===========================================
# Application Configuration
# ===========================================

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Enable debug mode (disables production optimizations)
DEBUG=false

# ===========================================
# Sentinel Configuration
# ===========================================

# Polling interval in seconds (min: 10, max: 300)
POLLING_INTERVAL_SECONDS=60

# Heartbeat comment interval in seconds (min: 60, max: 900)
HEARTBEAT_INTERVAL_SECONDS=300

# Maximum task execution time in seconds (min: 300, max: 14400)
TASK_TIMEOUT_SECONDS=5700

# Time threshold for marking tasks as stale in seconds (min: 300, max: 3600)
STALE_TASK_THRESHOLD_SECONDS=900

# ===========================================
# Worker Configuration
# ===========================================

# CPU limit for worker containers
WORKER_CPU_LIMIT=2.0

# Memory limit for worker containers in MB
WORKER_MEMORY_LIMIT_MB=4096
